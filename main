    <script>
        function showDay(dayId) {
            // Hide all cards
            document.querySelectorAll('.day-card').forEach(card => {
                card.classList.remove('active');
            });
            // Show selected card
            document.getElementById(dayId).classList.add('active');
            
            // Update button styles
            document.querySelectorAll('.day-btn').forEach(btn => {
                btn.classList.remove('text-white', 'border-white');
                btn.classList.add('text-indigo-200', 'border-transparent');
            });
            const activeBtn = document.getElementById('btn-' + dayId);
            activeBtn.classList.remove('text-indigo-200', 'border-transparent');
            activeBtn.classList.add('text-white', 'border-white');

            // Scroll to top
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Initialize first day
        window.onload = () => {
            showDay('day1');
        };
    </script>
